rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Sadece günlük hesap kayıtları — süresi dolmaz.
    // Tek bayi kullanımı için açık erişim.
    // İleride Firebase Authentication eklerseniz kuralları sıkılaştırın.
    match /kayitlar/{tarih} {
      allow read, write: if true;
    }
  }
}
